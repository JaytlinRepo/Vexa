# ─── SOVEXA ENVIRONMENT VARIABLES ─────────────────────────────────────────────
# Copy to apps/api/.env for the API server.
# Never commit actual values to git.

# ── ENVIRONMENT ──────────────────────────────────────────────────────────────
# "production" or unset for dev
NODE_ENV=

# ── DATABASE ─────────────────────────────────────────────────────────────────
# Dev:  Neon (free) — postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
# Prod: AWS RDS     — postgresql://sovexa_admin:pass@sovexa-prod.xxx.rds.amazonaws.com:5432/sovexa_prod?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── AUTH ─────────────────────────────────────────────────────────────────────
SESSION_SECRET=generate-a-random-32-char-string

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── ADMIN ────────────────────────────────────────────────────────────────────
# Comma-separated emails that can access /api/admin/* routes
ADMIN_EMAILS=

# ── INTEGRATIONS ─────────────────────────────────────────────────────────────
# Phyllo (multi-platform social data)
PHYLLO_API_BASE=https://api.staging.getphyllo.com
PHYLLO_CLIENT_ID=
PHYLLO_CLIENT_SECRET=
PHYLLO_ENVIRONMENT=staging

# Meta / Instagram
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_ACCOUNT_ID=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4000/api/tiktok/callback
INSTAGRAM_REDIRECT_URI=http://localhost:4000/api/instagram/auth/callback

# YouTube Data API v3
YOUTUBE_API_KEY=

# NewsAPI
NEWS_API_KEY=

# Stock media
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ── PAYMENTS (Stripe) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_...
STRIPE_AGENCY_ANNUAL_PRICE_ID=price_...

# ── EMAIL (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── VIDEO (Creatomate) ───────────────────────────────────────────────────────
CREATOMATE_API_KEY=

# ── CACHE (Redis) ────────────────────────────────────────────────────────────
# Local: redis://localhost:6379 (Docker)
# Prod:  ElastiCache or Upstash
REDIS_URL=redis://localhost:6379

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (auto-allows *.sovexa.ai and *.amplifyapp.com)
CORS_ORIGINS=http://localhost:3000

# ── URLS ─────────────────────────────────────────────────────────────────────
# Dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
PORT=4000

# Prod (set in App Runner env vars):
# NEXT_PUBLIC_APP_URL=https://sovexa.ai
# NEXT_PUBLIC_API_URL=https://api.sovexa.ai
