# ─── VEXA ENVIRONMENT VARIABLES ──────────────────────────────────────────────
# Copy this to .env.local (web) and .env (api) and fill in your values.
# Never commit actual values to git.

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BEDROCK_REGION=us-east-1

# Bedrock Knowledge Base IDs (create one per niche in AWS Bedrock console)
AWS_KNOWLEDGE_BASE_ID_FITNESS=
AWS_KNOWLEDGE_BASE_ID_FINANCE=
AWS_KNOWLEDGE_BASE_ID_FOOD=
AWS_KNOWLEDGE_BASE_ID_COACHING=
AWS_KNOWLEDGE_BASE_ID_LIFESTYLE=
AWS_KNOWLEDGE_BASE_ID_PERSONAL_DEV=

# S3
AWS_S3_BUCKET=vexa-outputs

# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vexa_admin:PASSWORD@YOUR-RDS-ENDPOINT:5432/vexa

# ── AUTH (AWS Cognito) ────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── PAYMENTS (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pricing tiers: Starter $14.99/mo ($11/mo annual), Pro $49/mo ($37/mo annual), Agency $99/mo ($74/mo annual)
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_...
STRIPE_AGENCY_ANNUAL_PRICE_ID=price_...

# ── INTEGRATIONS ──────────────────────────────────────────────────────────────
# Cost to start: ~$29/mo (Creatomate only — everything else is free)

# NewsAPI — free 100 req/day — https://newsapi.org
NEWS_API_KEY=

# YouTube Data API v3 — free 10k units/day — https://console.developers.google.com
YOUTUBE_API_KEY=

# Pexels — free 200 req/hour — https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay — free 100 req/min — https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# NO KEY NEEDED: Reddit (public JSON), Google Trends (npm package), RSS (open standard)

# ── VIDEO GENERATION ──────────────────────────────────────────────────────────
# Creatomate — $29/mo starter (1,000 renders) — https://creatomate.com
CREATOMATE_API_KEY=
CREATOMATE_TEMPLATE_REEL_BASIC=      # Create in Creatomate template editor
CREATOMATE_TEMPLATE_REEL_TEXT=       # Text-heavy reel variant
CREATOMATE_TEMPLATE_CAROUSEL=        # Carousel/slideshow variant

# ── EMAIL (Resend) ────────────────────────────────────────────────────────────
# Free up to 3,000 emails/month — https://resend.com
RESEND_API_KEY=

# ── CACHE (Redis) ─────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379 (run via Docker)
# AWS: ElastiCache Redis endpoint (~$13/mo for cache.t3.micro)
# Alt: Upstash free tier for dev (https://upstash.com)
REDIS_URL=redis://localhost:6379


NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MARKETING_URL=https://sovexa.ai

# Production:
# NEXT_PUBLIC_APP_URL=https://app.sovexa.ai
# NEXT_PUBLIC_API_URL=https://api.sovexa.ai
