{
  "name": "@vexa/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:prod": "prisma db push --skip-generate --accept-data-loss && node dist/index.js",
    "postinstall": "prisma generate || true",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:knowledge": "tsx scripts/seed-niche-knowledge.ts",
    "sync:all": "tsx scripts/sync-all.ts",
    "dev:test": "VEXA_MODE=test tsx watch src/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^3.600.0",
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-s3": "^3.1031.0",
    "@aws-sdk/s3-request-presigner": "^3.1031.0",
    "@prisma/client": "^5.14.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/multer": "^2.1.0",
    "@vexa/types": "*",
    "axios": "^1.7.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "creatomate": "^1.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "fluent-ffmpeg": "^2.1.3",
    "google-trends-api": "^4.9.2",
    "ioredis": "^5.4.0",
    "jose": "^6.2.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "resend": "^3.2.0",
    "stripe": "^15.8.0",
    "xml2js": "^0.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/xml2js": "^0.4.14",
    "prisma": "^5.14.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
