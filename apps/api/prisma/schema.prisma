// Vexa — Prisma Schema
// Database: PostgreSQL on AWS RDS

generator client {
  provider      = "prisma-client-js"
  // openssl-3 covers Railway's Nixpacks image and current Render images.
  // debian-openssl-1.1.x is for older Lambda / Amazon Linux 2 paths.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  trial
  active
  canceled
  past_due
}

enum Plan {
  starter
  pro
  agency
}

enum Platform {
  instagram
}

enum EmployeeRole {
  analyst
  strategist
  copywriter
  creative_director
}

enum TaskStatus {
  pending
  in_progress
  delivered
  approved
  rejected
  revision
}

enum OutputType {
  trend_report
  content_plan
  hooks
  caption
  script
  shot_list
  video
  performance_review
  weekly_pulse
  upload_review
  content_audit
  growth_strategy
  feed_audit
  format_analysis
  trend_hooks
  plan_adjustment
  competitor_analysis
  morning_brief
  midday_check
  evening_recap
}

enum OutputStatus {
  draft
  approved
  rejected
}

enum MemoryType {
  feedback
  preference
  performance
  voice
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id                   String             @id @default(uuid())
  email                String             @unique
  username             String?            @unique
  passwordHash         String?            @map("password_hash")
  cognitoId            String?            @unique @map("cognito_id")
  phylloUserId         String?            @unique @map("phyllo_user_id")
  fullName             String?            @map("full_name")
  subscriptionStatus   SubscriptionStatus @default(trial) @map("subscription_status")
  plan                 Plan               @default(starter)
  trialEndsAt          DateTime?          @map("trial_ends_at")
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  companies     Company[]
  notifications Notification[]

  @@map("users")
}

model Company {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  name       String
  niche         String
  subNiche      String?  @map("sub_niche")
  detectedNiche    String?  @map("detected_niche")
  detectedSubNiche String?  @map("detected_sub_niche")
  nicheConfidence  Float?   @map("niche_confidence")
  platform      Platform @default(instagram)
  brandVoice    Json     @default("{}") @map("brand_voice")
  audience      Json     @default("{}")
  goals         Json     @default("{}")
  agentTools    Json     @default("{}") @map("agent_tools")
  createdAt  DateTime @default(now()) @map("created_at")

  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  employees        Employee[]
  tasks            Task[]
  outputs          Output[]
  meetings         Meeting[]
  memory           BrandMemory[]
  instagram        InstagramConnection?
  tiktok           TiktokConnection?
  platformAccounts PlatformAccount[]

  @@map("companies")
}

model Employee {
  id         String       @id @default(uuid())
  companyId  String       @map("company_id")
  role       EmployeeRole
  name       String
  isActive   Boolean      @default(true) @map("is_active")
  lastActive DateTime?    @map("last_active")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks    Task[]
  outputs  Output[]
  meetings Meeting[]

  @@unique([companyId, role])
  @@map("employees")
}

model Task {
  id          String     @id @default(uuid())
  companyId   String     @map("company_id")
  employeeId  String     @map("employee_id")
  title       String
  description String?
  type        String
  status      TaskStatus @default(pending)
  userAction  Json?      @map("user_action")
  createdAt   DateTime   @default(now()) @map("created_at")
  completedAt DateTime?  @map("completed_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])
  outputs  Output[]

  @@map("tasks")
}

model Output {
  id         String       @id @default(uuid())
  taskId     String       @map("task_id")
  companyId  String       @map("company_id")
  employeeId String       @map("employee_id")
  type       OutputType
  content    Json
  status     OutputStatus @default(draft)
  feedback   Json?
  version    Int          @default(1)
  createdAt  DateTime     @default(now()) @map("created_at")

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("outputs")
}

model Meeting {
  id           String    @id @default(uuid())
  companyId    String    @map("company_id")
  employeeId   String    @map("employee_id")
  messages     Json      @default("[]")
  summary      String?
  decisions    Json?
  tasksCreated Json?     @map("tasks_created")
  startedAt    DateTime  @default(now()) @map("started_at")
  endedAt      DateTime? @map("ended_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("meetings")
}

model BrandMemory {
  id         String     @id @default(uuid())
  companyId  String     @map("company_id")
  memoryType MemoryType @map("memory_type")
  content    Json
  weight     Float      @default(1.0)
  createdAt  DateTime   @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("brand_memory")
}

// ─── PLATFORM DATA MODEL (multi-platform, time-series) ──────────────────────
// Each connected social account lives in PlatformAccount. Every sync writes
// a PlatformSnapshot (point-in-time KPIs), a PlatformAudience row (demo
// breakdown at that moment), and upserts one PlatformPost row per post we
// saw. Everything is scoped to a Company, and Company is scoped to a User,
// so tenant isolation is enforced at the app layer (findFirst + onDelete
// cascade). No user can read another user's rows.

enum SocialPlatform {
  instagram
  tiktok
  youtube
  twitter_x
  facebook
  twitch
  substack
  snapchat
  linkedin
  pinterest
  other
}

model PlatformAccount {
  id              String         @id @default(uuid())
  companyId       String         @map("company_id")
  platform        SocialPlatform
  platformUserId  String?        @map("platform_user_id") // e.g. Instagram user id
  handle          String
  displayName     String?        @map("display_name")
  profileUrl      String?        @map("profile_url")
  profileImageUrl String?        @map("profile_image_url")
  bio             String?
  accountType     String?        @map("account_type") // CREATOR / BUSINESS / PERSONAL
  phylloAccountId String?        @unique @map("phyllo_account_id")
  phylloUserId    String?        @map("phyllo_user_id")
  status          String         @default("connected") // connected / disconnected / expired
  connectedAt     DateTime       @default(now()) @map("connected_at")
  lastSyncedAt    DateTime       @default(now()) @map("last_synced_at")
  disconnectedAt  DateTime?      @map("disconnected_at")

  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  snapshots PlatformSnapshot[]
  posts           PlatformPost[]
  audiences       PlatformAudience[]
  weeklySummaries WeeklySummary[]

  @@unique([companyId, platform, handle])
  @@index([companyId])
  @@map("platform_accounts")
}

model PlatformSnapshot {
  id             String   @id @default(uuid())
  accountId      String   @map("account_id")
  capturedAt     DateTime @default(now()) @map("captured_at")
  followerCount  Int      @default(0) @map("follower_count")
  followingCount Int      @default(0) @map("following_count")
  postCount      Int      @default(0) @map("post_count")
  avgReach       Int      @default(0) @map("avg_reach")
  avgImpressions Int      @default(0) @map("avg_impressions")
  engagementRate Float    @default(0) @map("engagement_rate")

  account PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, capturedAt])
  @@map("platform_snapshots")
}

model PlatformPost {
  id              String    @id @default(uuid())
  accountId       String    @map("account_id")
  platformPostId  String    @map("platform_post_id")
  mediaType       String    @map("media_type") // REEL / CAROUSEL_ALBUM / IMAGE / VIDEO
  caption         String?
  url             String?
  thumbnailUrl    String?   @map("thumbnail_url")
  publishedAt     DateTime? @map("published_at")
  likeCount       Int       @default(0) @map("like_count")
  commentCount    Int       @default(0) @map("comment_count")
  shareCount      Int       @default(0) @map("share_count")
  saveCount       Int       @default(0) @map("save_count")
  viewCount       Int       @default(0) @map("view_count")
  reachCount      Int       @default(0) @map("reach_count")
  impressionCount Int       @default(0) @map("impression_count")

  // Derived metrics (computed per-post)
  engagementRate  Float     @default(0) @map("engagement_rate")
  saveRate        Float     @default(0) @map("save_rate")
  viralityScore   Float     @default(0) @map("virality_score")
  commentToLikeRatio    Float @default(0) @map("comment_to_like_ratio")
  viewToFollowerRatio   Float @default(0) @map("view_to_follower_ratio")
  captionLength   Int       @default(0) @map("caption_length")
  publishHour     Int?      @map("publish_hour")
  publishDayOfWeek Int?     @map("publish_day_of_week")
  engagementVelocity Float  @default(0) @map("engagement_velocity")
  decayRate       Float     @default(0) @map("decay_rate")

  lastSyncedAt    DateTime  @default(now()) @map("last_synced_at")

  account         PlatformAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metricSnapshots PostMetricSnapshot[]

  @@unique([accountId, platformPostId])
  @@index([accountId, publishedAt])
  @@map("platform_posts")
}

// Per-post metric snapshots — stored on every sync so we can compute
// weekly deltas (e.g. "this post gained 10 likes this week").
model PostMetricSnapshot {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  capturedAt DateTime @default(now()) @map("captured_at")
  likeCount     Int  @default(0) @map("like_count")
  commentCount  Int  @default(0) @map("comment_count")
  shareCount    Int  @default(0) @map("share_count")
  saveCount     Int  @default(0) @map("save_count")
  viewCount     Int  @default(0) @map("view_count")
  reachCount    Int  @default(0) @map("reach_count")

  post PlatformPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, capturedAt])
  @@map("post_metric_snapshots")
}

// Weekly summary per account — pre-computed after each sync.
// Agents read this instead of computing from raw snapshots.
model WeeklySummary {
  id           String   @id @default(uuid())
  accountId    String   @map("account_id")
  weekStart    DateTime @map("week_start") // Monday 00:00 UTC
  weekEnd      DateTime @map("week_end")   // Sunday 23:59 UTC

  // Account-level deltas
  followerStart  Int @default(0) @map("follower_start")
  followerEnd    Int @default(0) @map("follower_end")
  followerDelta  Int @default(0) @map("follower_delta")

  // Engagement
  avgEngagement  Float @default(0) @map("avg_engagement")
  avgReach       Int   @default(0) @map("avg_reach")

  // Post activity
  postsPublished Int @default(0) @map("posts_published")
  totalViews     Int @default(0) @map("total_views")
  totalLikes     Int @default(0) @map("total_likes")
  totalComments  Int @default(0) @map("total_comments")

  // Top post this week
  topPostId      String? @map("top_post_id")
  topPostViews   Int     @default(0) @map("top_post_views")
  topPostCaption String? @map("top_post_caption")

  // Computed insights
  bestDay        String? @map("best_day")      // "Monday", "Tuesday", etc.
  bestFormat     String? @map("best_format")    // "REEL", "CAROUSEL", "IMAGE"

  // Extended insights (derived metrics)
  followerGrowthPct Float @default(0) @map("follower_growth_pct")
  totalShares       Int   @default(0) @map("total_shares")
  totalSaves        Int   @default(0) @map("total_saves")
  avgSaveRate       Float @default(0) @map("avg_save_rate")
  avgViralityScore  Float @default(0) @map("avg_virality_score")
  avgCaptionLength  Float @default(0) @map("avg_caption_length")
  bestHour          Int?  @map("best_hour")
  consistencyScore  Float @default(0) @map("consistency_score")
  engagementTrend   String? @map("engagement_trend")  // "up", "stable", "down"
  formatMomentum    Json @default("[]") @map("format_momentum")  // [{format, avgEng, delta, trend}, ...]

  account PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, weekStart])
  @@index([accountId, weekStart])
  @@map("weekly_summaries")
}

model PlatformAudience {
  id              String   @id @default(uuid())
  accountId       String   @map("account_id")
  capturedAt      DateTime @default(now()) @map("captured_at")
  // Age buckets: [{bucket:'18-24', share:0.114}, ...]
  ageBreakdown    Json     @default("[]") @map("age_breakdown")
  // Gender buckets: [{bucket:'MALE', share:0.38}, {bucket:'FEMALE', share:0.40}, ...]
  genderBreakdown Json     @default("[]") @map("gender_breakdown")
  // [{bucket:'US', share:0.518}, {bucket:'BR', share:0.105}, ...]
  topCountries    Json     @default("[]") @map("top_countries")
  // [{bucket:'Atlanta, Georgia', share:0.139}, ...]
  topCities       Json     @default("[]") @map("top_cities")

  account PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, capturedAt])
  @@map("platform_audiences")
}

model InstagramConnection {
  id              String    @id @default(uuid())
  companyId       String    @unique @map("company_id")
  handle          String
  profileUrl      String?   @map("profile_url")
  accountType     String    @default("CREATOR") @map("account_type")
  bio             String?
  followerCount   Int       @default(0) @map("follower_count")
  followingCount  Int       @default(0) @map("following_count")
  postCount       Int       @default(0) @map("post_count")
  engagementRate  Float     @default(0) @map("engagement_rate")
  avgReach        Int       @default(0) @map("avg_reach")
  avgImpressions  Int       @default(0) @map("avg_impressions")
  topPosts        Json      @default("[]") @map("top_posts")
  recentMedia     Json      @default("[]") @map("recent_media")
  followerSeries  Json      @default("[]") @map("follower_series")
  audienceAge     Json      @default("{}") @map("audience_age")
  audienceGender  Json      @default("{}") @map("audience_gender")
  audienceTop     Json      @default("[]") @map("audience_top_countries")
  audienceCities  Json      @default("[]") @map("audience_top_cities")
  accessToken     String?   @map("access_token")
  refreshToken    String?   @map("refresh_token")
  tokenExpiresAt  DateTime? @map("token_expires_at")
  igUserId        String?   @map("ig_user_id")
  igBusinessId    String?   @map("ig_business_id")
  pageId          String?   @map("page_id")
  phylloAccountId String?   @unique @map("phyllo_account_id")
  platform        String    @default("instagram")
  source          String    @default("stub") // 'stub' | 'phyllo' | 'meta'
  connectedAt     DateTime  @default(now()) @map("connected_at")
  lastSyncedAt    DateTime  @default(now()) @map("last_synced_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("instagram_connections")
}

// TikTok Login Kit connection. Mirrors InstagramConnection's shape where the
// fields overlap; TikTok-specific identifiers (open_id / union_id) and the
// video list replace IG's recentMedia. `source` is 'tiktok' when written by
// the Login Kit handshake; 'stub' is reserved for future demo-data paths.
model TiktokConnection {
  id             String    @id @default(uuid())
  companyId      String    @unique @map("company_id")
  handle         String // @username
  displayName    String?   @map("display_name")
  bio            String?
  avatarUrl      String?   @map("avatar_url")
  profileUrl     String?   @map("profile_url") // TikTok deep link
  isVerified     Boolean   @default(false) @map("is_verified")
  followerCount  Int       @default(0) @map("follower_count")
  followingCount Int       @default(0) @map("following_count")
  videoCount     Int       @default(0) @map("video_count")
  likesCount     Int       @default(0) @map("likes_count")
  avgViews       Int       @default(0) @map("avg_views")
  avgLikes       Int       @default(0) @map("avg_likes")
  engagementRate Float     @default(0) @map("engagement_rate")
  reachRate      Float     @default(0) @map("reach_rate")
  topVideos      Json      @default("[]") @map("top_videos")
  recentVideos   Json      @default("[]") @map("recent_videos")
  openId         String    @map("open_id")
  unionId        String?   @map("union_id")
  accessToken    String?   @map("access_token")
  refreshToken   String?   @map("refresh_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  scopes         String?
  source         String    @default("tiktok")
  connectedAt    DateTime  @default(now()) @map("connected_at")
  lastSyncedAt   DateTime  @default(now()) @map("last_synced_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("tiktok_connections")
}

// ─── NICHE KNOWLEDGE (RAG) ─────────────────────────────────────────────────
// Each niche (fitness, finance, food, coaching, lifestyle) has a curated
// set of entries the agents pull from when reasoning. Entries are tagged
// by kind (pillar / audience / hook_pattern / format_signal / cadence /
// language / competitor_archetype / taboo) and scoped to the agent roles
// they should inform. Retrieval is currently keyword + tag based; an
// optional `embedding` column is reserved for upgrading to vector search
// later (Bedrock embeddings → pgvector) without a schema change.
//
// This is the RAG framework backing every agent prompt — it is the
// difference between a generic LLM and an agent that actually knows the
// creator's lane.
enum NicheKnowledgeKind {
  pillar
  audience
  hook_pattern
  format_signal
  cadence
  language
  competitor_archetype
  taboo
  framework
}

model NicheKnowledge {
  id        String             @id @default(uuid())
  niche     String // 'fitness' | 'finance' | 'food' | 'coaching' | 'lifestyle' | 'default'
  kind      NicheKnowledgeKind
  title     String
  body      String
  tags      String[]           @default([]) // keywords for retrieval
  forRoles  String[]           @default([]) // 'analyst' | 'strategist' | 'copywriter' | 'creative_director'
  weight    Float              @default(1.0)
  source    String? // attribution / provenance
  embedding Json? // reserved for vector search later
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  @@index([niche, kind])
  @@index([niche])
  @@map("niche_knowledge")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  companyId   String?  @map("company_id")
  type        String
  title       String
  body        String
  emoji       String
  actionUrl   String?  @map("action_url")
  actionLabel String?  @map("action_label")
  isRead      Boolean  @default(false) @map("is_read")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model WaitlistEntry {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  source    String?  @default("website")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist")
}
